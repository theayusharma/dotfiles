#font-family = JetBrains Mono Medium   # Medium weight for softer look
# theme = dracula
font-family = FiraCode Nerd Font SemBd
# gtk-tabs-location = hidden
scrollback-limit = 10_000
window-decoration = false
#font-family = Fira Code Retina 
# font-family = FiraCode Ner
font-size = 12
title=""
window-padding-x = 0
window-padding-y = 0
# window-padding-color = extend
#
# # Background and foreground colors (override theme for a ghostly touch)
# background = 1e222a
# foreground = e6e6e6

background-blur = false
background-opacity = 0.85
cursor-style = block
cursor-style-blink = false

clipboard-read = allow
clipboard-write = allow
# font-thicken = true
# # Keybindings (custom actions leveraging Ghostty's flexibility)
# keybind = ctrl+shift+t=new_tab
# keybind = ctrl+shift+w=close_surface
# keybind = ctrl+shift+n=new_window
# keybind = ctrl+z=ignore  # Black-hole ctrl+z to prevent accidental suspend
# # Bell behavior (disable audible bell for a silent ghost)
# bell = none
# # Window settings
# window-decoration = true
# window-theme = ghostty resize-overlay-duration = 4s 200ms
#
shell-integration = fish

gtk-single-instance = detect
gtk-wide-tabs = false
# theme = catppuccin-frappe
#
# Matches: font_features all +ss01 +ss02 +ss03 +ss04
font-feature = +ss01
font-feature = +ss02
font-feature = +ss03
font-feature = +ss04

# --- PERSISTENCE (THE TMUX KILLER) ---
# Saves splits, tabs, and working directories on exit.
# No double-rendering layer involved.
window-save-state = always

# --- ENVIRONMENT ---
# Tells Yazi to use the Kitty protocol (Ghostty supports this natively)
# env-var = YAZI_IMAGE_BACKEND=kitty

# --- SCROLLBACK (NVCHAD STYLE) ---
# Matches: map alt+s show_scrollback
# Opens history in your default $EDITOR (nvim)
keybind = alt+s=write_scrollback_file:open

# --- KEYBINDINGS: KITTY DEFAULTS ---

# 1. Splits (Windows in Kitty terms)
# Ctrl+Shift+Enter -> New Split (Intelligent placement)
keybind = ctrl+shift+enter=new_split:auto
# Ctrl+Shift+W -> Close Split
keybind = ctrl+shift+q=close_surface
# Ctrl+Shift+] -> Next Split
keybind = ctrl+shift+]=goto_split:next
# Ctrl+Shift+[ -> Previous Split
keybind = ctrl+shift+[=goto_split:previous
# Ctrl+Shift+L -> Zoom into split (Maximized)
keybind = ctrl+shift+l=toggle_split_zoom

# 2. Tabs
# Ctrl+Shift+T -> New Tab
keybind = ctrl+shift+t=new_tab
# Ctrl+Shift+Q -> Close Tab
keybind = ctrl+shift+w=close_tab
# Ctrl+Shift+Right -> Next Tab
keybind = ctrl+shift+right=next_tab
# Ctrl+Shift+Left -> Previous Tab
keybind = ctrl+shift+left=previous_tab

# 3. Scrolling
keybind = ctrl+shift+up=scroll_to_top
keybind = ctrl+shift+down=scroll_to_bottom
keybind = ctrl+shift+page_up=scroll_page_up
keybind = ctrl+shift+page_down=scroll_page_down

keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
